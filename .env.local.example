# Copy to `.env.local` and fill in real values from Supabase Studio
# → https://supabase.com/dashboard/project/_/settings/api
#
# `.env.local` is gitignored. Never commit real secrets.

# From "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# From "Project API keys" → "anon public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: server-only key for admin operations (invite user, etc).
# Used by Server Actions in app/(app)/actions/members.ts in S1.5+
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
